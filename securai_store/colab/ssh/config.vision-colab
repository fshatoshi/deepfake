# Bloc SSH — SecurAI Colab (Étape 4 CDC)
# Test : ssh vision-colab
# HostName = sous-domaine Cloudflare (ex. vision.api.near-u-api.org)

Host vision-colab
    HostName vision.api.near-u-api.org
    User root
    Port 22
    ProxyCommand cloudflared access ssh --hostname %h
    StrictHostKeyChecking no
    UserKnownHostsFile NUL
